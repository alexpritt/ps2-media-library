# Frontend env variables
# Copy to .env.local for local dev or set in Cloudflare Pages.

# Backend API base
VITE_API_BASE_URL=http://127.0.0.1:8000

# Boot video split playback
# One-time intro clip URL
VITE_BOOT_INTRO_SRC=https://media.theavenoircollection.com/ps2-intro-intro.mp4

# Looping ambient clip URL
VITE_BOOT_LOOP_SRC=https://media.theavenoircollection.com/ps2-intro-loop.mp4
