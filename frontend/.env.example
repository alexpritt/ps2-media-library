# Frontend env variables
# Copy to .env.local for local dev or set in Cloudflare Pages.

# Backend used by the Vite dev proxy
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional boot intro clip URL for desktop
# Leave unset to use the hosted R2 intro at https://media.theavenoircollection.com/ps2-intro.mp4.
VITE_BOOT_INTRO_SRC=https://media.theavenoircollection.com/ps2-intro.mp4
