<svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg" width="256" height="256">
  <defs>
    <linearGradient id="ps2discgrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(0,0,0,0.15);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(0,0,0,0.4);stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- PS2 disc overlay -->
  <circle cx="128" cy="128" r="120" fill="url(#ps2discgrad)"/>
  <circle cx="128" cy="128" r="116" stroke="rgba(255,255,255,0.2)" stroke-width="2" fill="none"/>
  <!-- Center hole -->
  <circle cx="128" cy="128" r="25" fill="rgba(0,0,0,0.3)"/>
  <circle cx="128" cy="128" r="22" stroke="rgba(100,100,100,0.3)" stroke-width="1" fill="none"/>
  <!-- Glossy shine -->
  <ellipse cx="90" cy="90" rx="60" ry="50" fill="rgba(255,255,255,0.1)"/>
  <!-- Disc ring detail -->
  <circle cx="128" cy="128" r="80" stroke="rgba(255,255,255,0.08)" stroke-width="1" fill="none"/>
  <circle cx="128" cy="128" r="50" stroke="rgba(255,255,255,0.06)" stroke-width="1" fill="none" stroke-dasharray="5,5"/>
</svg>