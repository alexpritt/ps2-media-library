<svg viewBox="0 0 140 160" xmlns="http://www.w3.org/2000/svg" width="140" height="160">
  <defs>
    <linearGradient id="3dscartridge" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(0,0,0,0.1);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(0,0,0,0.35);stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- 3DS cartridge overlay -->
  <rect width="140" height="160" fill="url(#3dscartridge)" rx="10"/>
  <path d="M 8 8 L 132 8 L 132 152 L 8 152 Z" stroke="rgba(255,255,255,0.25)" stroke-width="1" fill="none" rx="5"/>
  <!-- Label area -->
  <rect x="12" y="20" width="116" height="110" fill="rgba(100,100,100,0.08)"/>
  <!-- Top notch -->
  <rect x="48" y="2" width="44" height="10" fill="rgba(0,0,0,0.2)" rx="2"/>
  <!-- Glossy -->
  <ellipse cx="38" cy="38" rx="32" ry="28" fill="rgba(255,255,255,0.1)"/>
  <!-- 3D indicator -->
  <line x1="20" y1="8" x2="20" y2="14" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
</svg>