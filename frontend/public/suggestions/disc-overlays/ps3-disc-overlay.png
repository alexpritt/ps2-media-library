<svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg" width="256" height="256">
  <defs>
    <linearGradient id="ps3discgrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(0,0,0,0.12);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(0,0,0,0.35);stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- PS3 disc overlay -->
  <circle cx="128" cy="128" r="120" fill="url(#ps3discgrad)"/>
  <circle cx="128" cy="128" r="116" stroke="rgba(255,255,255,0.25)" stroke-width="2" fill="none"/>
  <!-- Center hole -->
  <circle cx="128" cy="128" r="28" fill="rgba(0,0,0,0.2)"/>
  <circle cx="128" cy="128" r="25" stroke="rgba(150,150,150,0.3)" stroke-width="1" fill="none"/>
  <!-- Glossy shine -->
  <ellipse cx="85" cy="85" rx="65" ry="55" fill="rgba(255,255,255,0.12)"/>
  <!-- Disc ring detail -->
  <circle cx="128" cy="128" r="85" stroke="rgba(255,255,255,0.1)" stroke-width="1" fill="none"/>
</svg>