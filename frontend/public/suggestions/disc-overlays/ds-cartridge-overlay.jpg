<svg viewBox="0 0 140 160" xmlns="http://www.w3.org/2000/svg" width="140" height="160">
  <defs>
    <linearGradient id="dscartridge" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(0,0,0,0.1);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(0,0,0,0.35);stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- DS cartridge overlay -->
  <rect width="140" height="160" fill="url(#dscartridge)" rx="8"/>
  <path d="M 8 8 L 132 8 L 132 152 L 8 152 Z" stroke="rgba(255,255,255,0.2)" stroke-width="1" fill="none" rx="4"/>
  <!-- Label area -->
  <rect x="12" y="20" width="116" height="110" fill="rgba(100,100,100,0.08)"/>
  <!-- Top notch -->
  <rect x="50" y="4" width="40" height="8" fill="rgba(0,0,0,0.2)" rx="1"/>
  <!-- Glossy -->
  <ellipse cx="40" cy="40" rx="30" ry="25" fill="rgba(255,255,255,0.08)"/>
</svg>