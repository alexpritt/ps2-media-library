<svg viewBox="0 0 128 256" xmlns="http://www.w3.org/2000/svg" width="128" height="256">
  <defs>
    <linearGradient id="dsgrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(0,0,0,0.1);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(0,0,0,0.3);stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- 3DS cartridge case overlay -->
  <rect width="128" height="256" fill="url(#dsgrad)" rx="8"/>
  <path d="M 6 6 L 122 6 L 122 250 L 6 250 Z" stroke="rgba(255,255,255,0.25)" stroke-width="1" fill="none" rx="4"/>
  <!-- Cartridge label area -->
  <rect x="8" y="20" width="112" height="140" fill="rgba(100,100,100,0.1)"/>
  <!-- 3DS design element -->
  <line x1="20" y1="15" x2="108" y2="15" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
</svg>