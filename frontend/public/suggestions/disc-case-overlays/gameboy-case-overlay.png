<svg viewBox="0 0 100 150" xmlns="http://www.w3.org/2000/svg" width="100" height="150">
  <defs>
    <linearGradient id="gbgrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:rgba(0,0,0,0.1);stop-opacity:1" />
      <stop offset="100%" style="stop-color:rgba(0,0,0,0.3);stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- GameBoy cartridge case overlay -->
  <rect width="100" height="150" fill="url(#gbgrad)" rx="4"/>
  <path d="M 4 4 L 96 4 L 96 146 L 4 146 Z" stroke="rgba(255,255,255,0.2)" stroke-width="1" fill="none" rx="2"/>
  <!-- Cartridge label area -->
  <rect x="6" y="12" width="88" height="100" fill="rgba(100,100,100,0.08)"/>
  <!-- Glossy -->
  <ellipse cx="30" cy="30" rx="20" ry="15" fill="rgba(255,255,255,0.06)"/>
</svg>