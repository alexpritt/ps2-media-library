FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Seed the persistent volume with your existing DB on first boot only
CMD ["sh", "-c", "if [ ! -f /data/media.db ]; then cp /app/media.db /data/media.db; fi && uvicorn main:app --host 0.0.0.0 --port 8080"]